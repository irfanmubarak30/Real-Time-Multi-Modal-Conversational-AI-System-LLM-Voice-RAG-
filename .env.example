# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Pinecone Configuration
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIORNMENT=your_pinecone_environment_here

# Google API Configuration
GOOGLE_API_KEY=your_google_api_key_here

# Twilio WhatsApp Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_whatsapp_number_here

# Airtable Configuration (Optional)
AIRTABLE_API_KEY=your_airtable_api_key_here
AIRTABLE_BASE_ID=your_airtable_base_id_here
AIRTABLE_TABLE_NAME=Leads

# Google Sheets Configuration
USERS_SHEET_ID=your_users_google_sheet_id_here
SURVEY_SHEET_ID=your_survey_google_sheet_id_here

# Instructions for Google Sheets Setup:
# 1. Create two Google Sheets:
#    - users_sheet: columns should be "name" and "number"
#    - survey_sheet: columns should be "name", "number", "gmail", "role", "tech_background", "motivation_to_tech", "area_of_interest"
# 2. Get the Sheet IDs from the URLs (the long string between /spreadsheets/d/ and /edit)
# 3. Make sure your Google service account has access to both sheets
# 4. Place your Google service account credentials JSON file in: credentials/google-sheets-key.json
